        "(\\d+(?:\\.\\d+)?)\\s*(?:屑屑[虏2]|泻胁\\.?\\s*屑屑|泻胁邪写褉邪褌薪褘褏\\s*屑懈谢谢懈屑械褌褉芯胁)",
        "褋械褔械薪懈械屑\\s*(\\d+(?:\\.\\d+)?)",
        "(\\d+(?:\\.\\d+)?)\\s*[褏x]\\s*(\\d+(?:\\.\\d+)?)"
      ],
      "extract_group": 2
    },
    "voltage": {
      "patterns": [
        "(\\d+(?:\\.\\d+)?)\\s*(?:泻胁|泻懈谢芯胁芯谢褜褌)",
        "薪邪锌褉褟卸械薪懈械屑\\s*(\\d+(?:\\.\\d+)?)",
        "(\\d+(?:\\.\\d+)?)\\s*泻胁"
      ],
      "extract_group": 1
    },
    "standard": {
      "patterns": [
        "(谐芯褋褌\\s*\\d+(?:[.-]\\d+)*)",
        "(褌褍\\s*\\d+(?:[.-]\\d+)*)"
