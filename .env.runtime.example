# Copy to .env.local with mode 0600. Never commit real credentials.
AI_CORP_DATABASE_URL=postgresql+psycopg://arvectum:CHANGE_ME@127.0.0.1:55432/arvectum
ARVECTUM_POSTGRES_DB=arvectum
ARVECTUM_POSTGRES_USER=arvectum
ARVECTUM_POSTGRES_PASSWORD=CHANGE_ME
AI_CORP_RUNTIME_PROFILE=production
AI_CORP_BACKEND_PORT=8001
AI_CORP_LOCAL_LLM_BASE_URL=http://127.0.0.1:8088/v1
AI_CORP_RAG_EMBEDDINGS_BASE_URL=http://127.0.0.1:8090/v1
AI_CORP_ALLOWED_HOSTS=api.arvectum.com
AI_CORP_CORS_ALLOW_ORIGINS=https://arvectum.com,https://www.arvectum.com
AI_CORP_PILOT_AUTH_ENABLED=true
AI_CORP_PILOT_AUTH_USERNAME=pilot_operator
AI_CORP_PILOT_AUTH_PASSWORD=CHANGE_ME
AI_CORP_PILOT_AUTH_PROTECTED_PREFIXES=/api,/demo,/pilot,/docs,/redoc,/openapi.json,/health/ready
AI_CORP_PILOT_AUTH_PUBLIC_PATHS=/health
AI_CORP_HERMES_ENABLED=false
ZAKUPKI_GOV_RU_SOAP_ENABLED=false
