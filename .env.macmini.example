AI_CORP_DATABASE_URL=postgresql+psycopg://arvectum:CHANGE_ME@127.0.0.1:5432/arvectum
ARVECTUM_POSTGRES_DB=arvectum
ARVECTUM_POSTGRES_USER=arvectum
ARVECTUM_POSTGRES_PASSWORD=CHANGE_ME
AI_CORP_DEBUG=false
AI_CORP_ALLOWED_HOSTS=localhost,127.0.0.1,*.trycloudflare.com,*.ngrok-free.app,api.arvectum.com
AI_CORP_CORS_ALLOW_ORIGINS=https://arvectum.com,https://www.arvectum.com
AI_CORP_TENDER_PILOT_BASIC_AUTH_ENABLED=true
AI_CORP_TENDER_PILOT_BASIC_AUTH_USERNAME=demo
AI_CORP_TENDER_PILOT_BASIC_AUTH_PASSWORD=replace_me_do_not_commit_real_password
AI_CORP_LLM_PROVIDER=openai_compatible
AI_CORP_LLM_MODEL=local-model
AI_CORP_OPENAI_BASE_URL=http://host.docker.internal:8088/v1
AI_CORP_OPENAI_API_KEY=llama-cpp-local
AI_CORP_LLM_TIMEOUT_SECONDS=180
AI_CORP_LLM_MAX_RETRIES=1
AI_CORP_LLM_ALLOW_RAW_PARTNER_DATA=false
AI_CORP_LLM_STORE_RAW_RESPONSE=false
ZAKUPKI_GOV_RU_SOAP_ENABLED=false
