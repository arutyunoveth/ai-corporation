	<xs:element name="getPreparedPartRequest">
		<xs:annotation>
			<xs:documentation>Запрос информации о подготовленных архивах по ранее направленному запросу</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="index" type="indexRequestType">
					<xs:annotation>
						<xs:documentation>Индексная карточка информационного пакета</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:sequence>
					<xs:element name="docRequestUid" type="guidType">
						<xs:annotation>
							<xs:documentation>Глобальный идентификатор ранее направленного запроса на получение документов</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="getPreparedPartResponse">
		<xs:annotation>
			<xs:documentation>Ответ на запрос информации о подготовленных архивах по ранее направленному запросу</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="index" type="indexResponseType">
					<xs:annotation>
						<xs:documentation>Индексная карточка информационного пакета</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="docRequestUid" type="guidType">
					<xs:annotation>
						<xs:documentation>Глобальный идентификатор ранее направленного запроса на получение документов</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:choice>
					<xs:element name="dataInfo">
						<xs:annotation>
							<xs:documentation>Результат обработки запроса</xs:documentation>
						</xs:annotation>
						<xs:complexType>
							<xs:sequence>
								<xs:element name="isPreparationCompleted" type="xs:boolean">
									<xs:annotation>
										<xs:documentation>Признак завершения подготовки всех архивов по запросу docRequestUid.

false - подготовка архивов продолжается;
true - подготовка архивов завершена, все архивы подготовлены</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="preparedPartInfo" minOccurs="0" maxOccurs="100000">
									<xs:annotation>
										<xs:documentation>Информация о подготовленных архивах</xs:documentation>
									</xs:annotation>
									<xs:complexType>
										<xs:sequence>
											<xs:element name="dsUid" type="base:UUID32Type">
												<xs:annotation>
													<xs:documentation>Идентификатор архива в ХД</xs:documentation>
												</xs:annotation>
											</xs:element>
											<xs:element name="url" type="base:hrefType">
												<xs:annotation>
													<xs:documentation>Ссылка для скачивания архива</xs:documentation>
												</xs:annotation>
											</xs:element>
											<xs:element name="lastDownloadDT" type="xs:dateTime" minOccurs="0">
												<xs:annotation>
													<xs:documentation>Дата и время последнего скачивания архива.

Если поле не заполнено в ответе, то данный архив не скачивался</xs:documentation>
												</xs:annotation>
											</xs:element>
										</xs:sequence>
									</xs:complexType>
								</xs:element>
								<xs:element name="preparedNotDownloadPartInfo" minOccurs="0" maxOccurs="100000">
									<xs:annotation>
										<xs:documentation>Информация о подготовленных и еще не скачанных архивах</xs:documentation>
									</xs:annotation>
									<xs:complexType>
										<xs:sequence>
											<xs:element name="dsUid" type="base:UUID32Type">
												<xs:annotation>
													<xs:documentation>Идентификатор архива в ХД</xs:documentation>
												</xs:annotation>
											</xs:element>
											<xs:element name="url" type="base:hrefType">
												<xs:annotation>
													<xs:documentation>Ссылка для скачивания архива</xs:documentation>
												</xs:annotation>
											</xs:element>
										</xs:sequence>
									</xs:complexType>
								</xs:element>
							</xs:sequence>
						</xs:complexType>
					</xs:element>
					<xs:element name="errorInfo" type="errorInfoType">
						<xs:annotation>
							<xs:documentation>Результат вызова сервиса в случае ошибки</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:choice>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="getNsiRequest">
		<xs:annotation>
			<xs:documentation>Запрос в ХД данных справочника</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="index" type="indexRequestType">
					<xs:annotation>
						<xs:documentation>Индексная карточка информационного пакета</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="selectionParams">
					<xs:annotation>
						<xs:documentation>Параметры запрашиваемого справочника</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:choice>
								<xs:annotation>
									<xs:documentation>Сервисом поддерживается отдача публичных справочников, которые присутствуют в справочнике "Перечень справочников ЕИС" (nsiAllList) в актуальном статусе.

Примечание: справочники, которые находятся в неактуальном статусе, также доступны через сервис, но могут содержать устаревшие данные. Рекомендуется не использовать неактуальные справочники.

Допустимые значения:
1. nsiAllList для получения перечня справочников ЕИС
2. значения nsiCode из справочника nsiAllList</xs:documentation>
								</xs:annotation>
								<xs:element name="nsiCode44" type="base:nsiAllListCodeType">
									<xs:annotation>
										<xs:documentation>Код справочника 44-ФЗ</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="nsiCode223" type="base:nsiAllListCodeType">
									<xs:annotation>
										<xs:documentation>Код справочника 223-ФЗ</xs:documentation>
									</xs:annotation>
								</xs:element>
							</xs:choice>
							<xs:element name="nsiKind" type="nsiKindType">
								<xs:annotation>
									<xs:documentation>Вид выгрузки.

Допустимые значения:
all - полная выгрузка справочника
inc - инкрементальная выгрузка справочника</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="getNsiResponse">
		<xs:annotation>
			<xs:documentation>Ответ на запрос в ХД данных справочника</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="index" type="indexResponseType">
					<xs:annotation>
						<xs:documentation>Индексная карточка информационного пакета</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="dataInfo">
					<xs:annotation>
						<xs:documentation>Результат обработки запроса</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="nsiArchiveInfo" maxOccurs="1000">
								<xs:annotation>
									<xs:documentation>Справочники найдены</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:sequence>
										<xs:element name="archiveUrl" type="base:hrefType">
											<xs:annotation>
												<xs:documentation>Ссылка для скачивания архива со справочной информацией</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="archiveName" type="fileNameType">
											<xs:annotation>
												<xs:documentation>Наименование архива</xs:documentation>
											</xs:annotation>
										</xs:element>
									</xs:sequence>
								</xs:complexType>
							</xs:element>
							<xs:element name="noData" type="xs:boolean" fixed="true">
								<xs:annotation>
									<xs:documentation>Справочники не найдены</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="errorInfo" type="errorInfoType">
								<xs:annotation>
									<xs:documentation>Результат вызова сервиса в случае ошибки</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:choice>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<!--Общие типы-->
	<xs:complexType name="errorInfoType">
		<xs:annotation>
			<xs:documentation>Тип: Результат вызова сервиса в случае ошибки</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="code" type="xs:int">
				<xs:annotation>
					<xs:documentation>Код ошибки</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="message" type="base:text2000Type">
				<xs:annotation>
					<xs:documentation>Текстовая расшифровка ошибки, включающая дополнительную информацию
                    </xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="indexRequestType">
		<xs:annotation>
			<xs:documentation>Тип: Индексная карточка пакета данных</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="id" type="guidType">
				<xs:annotation>
					<xs:documentation>Глобальный идентификатор запроса</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="createDateTime" type="xs:dateTime">
				<xs:annotation>
					<xs:documentation>Дата и время формирования информационного пакета</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="mode" type="base:indexModeType">
				<xs:annotation>
					<xs:documentation>Режим передачи информации
			PROD - промышленная эксплуатация
			TEST - тестовые данные</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="indexResponseType">
		<xs:annotation>
			<xs:documentation>Тип: Индексная карточка пакета данных</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="id" type="guidType">
				<xs:annotation>
					<xs:documentation>Глобальный идентификатор ответа</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="refId" type="guidType">
				<xs:annotation>
					<xs:documentation>Глобальный идентификатор запроса</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="createDateTime" type="xs:dateTime">
				<xs:annotation>
					<xs:documentation>Дата и время формирования информационного пакета</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="mode" type="base:indexModeType">
				<xs:annotation>
					<xs:documentation>Режим передачи информации
			PROD - промышленная эксплуатация
			TEST - тестовые данные</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
