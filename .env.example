# Local dev/test default:
AI_CORP_DATABASE_URL=sqlite:///./ai_corporation.db
# Mac mini / server contour example:
# AI_CORP_DATABASE_URL=postgresql+psycopg://arvectum:CHANGE_ME@127.0.0.1:5432/arvectum
ARVECTUM_POSTGRES_DB=arvectum
ARVECTUM_POSTGRES_USER=arvectum
ARVECTUM_POSTGRES_PASSWORD=CHANGE_ME
AI_CORP_DEBUG=false
AI_CORP_SITE_PUBLIC_ROOT=
AI_CORP_ALLOWED_HOSTS=127.0.0.1,localhost
AI_CORP_CORS_ALLOW_ORIGINS=
AI_CORP_TENDER_PILOT_BASIC_AUTH_ENABLED=false
AI_CORP_TENDER_PILOT_BASIC_AUTH_USERNAME=pilot_operator
AI_CORP_TENDER_PILOT_BASIC_AUTH_PASSWORD=change_me_local_only

# Controlled cloud LLM provider layer.
# Keep real credentials in local-only env files. Never commit real secrets.
AI_CORP_LLM_PROVIDER=stub
AI_CORP_LLM_MODEL=
AI_CORP_LLM_TIMEOUT_SECONDS=30
AI_CORP_LLM_MAX_RETRIES=1
AI_CORP_LLM_ALLOW_RAW_PARTNER_DATA=false
AI_CORP_LLM_STORE_RAW_RESPONSE=false

# OpenAI-compatible / Cloud.ru-compatible settings.
AI_CORP_OPENAI_API_KEY=
AI_CORP_OPENAI_BASE_URL=https://api.openai.com/v1
AI_CORP_CLOUDRU_API_KEY=
AI_CORP_CLOUDRU_BASE_URL=https://foundation-models.api.cloud.ru/v1

# Yandex AI Studio / Alice AI settings.
AI_CORP_YANDEX_API_KEY=
AI_CORP_YANDEX_IAM_TOKEN=
AI_CORP_YANDEX_BASE_URL=https://ai.api.cloud.yandex.net/v1

# GigaChat settings.
AI_CORP_GIGACHAT_AUTH_KEY=
AI_CORP_GIGACHAT_SCOPE=GIGACHAT_API_PERS
AI_CORP_GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
AI_CORP_GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1

# Zakupki.gov.ru SOAP intake demo source.
# Keep real tokens in .env.local only. Never commit real credentials.
ZAKUPKI_GOV_RU_SOAP_ENABLED=0
ZAKUPKI_GOV_RU_SOAP_TOKEN_OWNER=individual
ZAKUPKI_GOV_RU_SOAP_TOKEN=replace_me_do_not_commit_real_token
ZAKUPKI_GOV_RU_SOAP_INDIVIDUAL_BASE_URL=https://int.zakupki.gov.ru/eis-integration/services/getDocsIP
ZAKUPKI_GOV_RU_SOAP_INDIVIDUAL_XSD_URL=https://int.zakupki.gov.ru/eis-integration/services/getDocsIP?xsd=getDocsIP-ws-api.xsd
ZAKUPKI_GOV_RU_SOAP_INDIVIDUAL_NAMESPACE=http://zakupki.gov.ru/fz44/get-docs-ip/ws
ZAKUPKI_GOV_RU_SOAP_TOKEN_HEADER_NAME=individualPerson_token
ZAKUPKI_GOV_RU_SOAP_MODE=PROD
ZAKUPKI_GOV_RU_SOAP_DISABLE_PROXY_FOR_EIS=1
ZAKUPKI_GOV_RU_SOAP_REQUIRE_DIRECT_RU_ROUTE=1
ZAKUPKI_GOV_RU_SOAP_ALLOWED_HOSTS=zakupki.gov.ru,.zakupki.gov.ru,int.zakupki.gov.ru,int44.zakupki.gov.ru,int44-ttls-cert.zakupki.gov.ru
ZAKUPKI_GOV_RU_SOAP_USER_AGENT=ArvectumTenderAgent/0.1 read-only
# Document export token (issued after registering as machine-readable data recipient).
# Priority over ZAKUPKI_GOV_RU_SOAP_TOKEN for GetDocsIP operations when set.
ZAKUPKI_GOV_RU_DOCUMENT_EXPORT_TOKEN=
ZAKUPKI_GOV_RU_SOAP_CONTENT_TYPE=text/xml; charset=utf-8
ZAKUPKI_GOV_RU_SOAP_USE_SOAP_ACTION=1
ZAKUPKI_GOV_RU_SOAP_SOAP_ACTION=http://zakupki.gov.ru/fz44/queue/ws/get-docs-ip
# Legacy legal-entity endpoint, kept only as experimental/legacy mode.
ZAKUPKI_GOV_RU_SOAP_BASE_URL=https://int44.zakupki.gov.ru/eis-integration/services-vbs
ZAKUPKI_GOV_RU_SOAP_SEARCH_ACTION=searchProcurements
ZAKUPKI_GOV_RU_SOAP_DETAILS_ACTION=getProcurementDetails
ZAKUPKI_GOV_RU_SOAP_ATTACHMENTS_ACTION=listAttachments
ZAKUPKI_GOV_RU_SOAP_TIMEOUT_SECONDS=30
ZAKUPKI_GOV_RU_SOAP_MAX_RESULTS=10
ZAKUPKI_GOV_RU_SOAP_MAX_ATTACHMENTS=20
ZAKUPKI_GOV_RU_SOAP_MAX_DOWNLOAD_MB=200
ZAKUPKI_GOV_RU_SOAP_TRUST_ENV_PROXY=0
ZAKUPKI_GOV_RU_SOAP_DEBUG=0
